            key: ios-deps-${{ hashFiles('scripts/build_ios_deps.sh') }}

        - name: Build third-party deps for iOS
          run: |
            chmod +x scripts/build_ios_deps.sh
            scripts/build_ios_deps.sh

        - name: Configure BionicSX2
          run: |
            cmake -S . -B build-ios \
              -DCMAKE_TOOLCHAIN_FILE=cmake/ios.toolchain.cmake \
              -DCMAKE_BUILD_TYPE=Release \
              -DENABLE_QT=OFF -DENABLE_OPENGL=OFF \
              -DENABLE_VULKAN=OFF -DUSE_SDL=OFF \
              -DBUILD_TESTS=OFF

        - name: Build BionicSX2
          run: |
            set -euxo pipefail
            cmake --build build-ios \
              --config Release \
              -j"$(sysctl -n hw.logicalcpu)"

        - name: Verify Build Output
          run: |
            set -euxo pipefail
            APP="build-ios/BionicSX2.app/BionicSX2"
            test -f "$APP"
            SIZE=$(stat -f%z "$APP")
            echo "Binary size: $SIZE bytes"
            if [ "$SIZE" -lt 5000000 ]; then
              echo "ERROR: Binary too small — likely missing emulator core"
              exit 1
            fi
            nm "$APP" | grep -E 'cpuReset|SysMemory|GSopen' >/dev/null

        - name: Package IPA
          run: |
            xcodebuild -exportArchive \
              -archivePath build-ios/BionicSX2.xcarchive \
              -exportPath build-ios/export \
              -exportOptionsPlist ios/ExportOptions.plist
              CODE_SIGN_IDENTITY="" PROVISIONING_PROFILE=""

        - name: Upload IPA artifact
          uses: actions/upload-artifact@v4
          with:
            name: BionicSX2-IPA
            path: build-ios/export/*.ipa

